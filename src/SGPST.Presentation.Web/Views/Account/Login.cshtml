@model SGPST.Application.DTOs.Auth.LoginDto
@{
    ViewData["Title"] = "Entrar";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center animate-fade-in" style="min-height: 75vh;">
    <div class="col-md-5">
        <div class="glass-card text-center p-5">
            <div class="mb-4">
                <i class="bi bi-cpu-fill" style="font-size: 3rem; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                <h2 class="mt-3 font-weight-bold">SGPST Enterprise</h2>
                <p class="text-muted">Autentique-se para acessar o painel administrativo</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="text-start">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label for="Username" class="form-label text-secondary">Usuario</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-secondary"><i class="bi bi-person-fill"></i></span>
                        <input type="text" id="Username" name="Username" class="form-control form-glass" placeholder="Digite seu usuario" required autofocus />
                    </div>
                </div>

                <div class="mb-4">
                    <label for="Password" class="form-label text-secondary">Senha</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-secondary"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" id="Password" name="Password" class="form-control form-glass" placeholder="Digite sua senha" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-gradient w-100 py-3 mb-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Entrar no Sistema
                </button>
            </form>

            <hr class="border-secondary my-4" />

            <div class="text-start bg-dark bg-opacity-50 p-3 rounded-3 border border-secondary border-opacity-50">
                <h6 class="text-accent mb-2"><i class="bi bi-info-circle-fill me-2"></i>Credenciais de Demonstracao:</h6>
                <div class="row g-2 small">
                    <div class="col-6"><span class="text-light font-weight-bold">Admin:</span> <code class="text-info">admin</code> / <code class="text-info">admin123</code></div>
                    <div class="col-6"><span class="text-light font-weight-bold">Atendente:</span> <code class="text-info">atendente</code> / <code class="text-info">atendente123</code></div>
                    <div class="col-6"><span class="text-light font-weight-bold">Tecnico:</span> <code class="text-info">tecnico</code> / <code class="text-info">tecnico123</code></div>
                    <div class="col-6"><span class="text-light font-weight-bold">Cliente:</span> <code class="text-info">cliente</code> / <code class="text-info">cliente123</code></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
