@{
    ViewData["Title"] = "Acesso Negado";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center animate-fade-in" style="min-height: 70vh;">
    <div class="col-md-6 text-center">
        <div class="glass-card p-5">
            <div class="mb-4">
                <i class="bi bi-shield-slash-fill text-danger" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-5 text-danger font-weight-bold mb-3">Acesso Negado</h1>
            <p class="text-secondary mb-4 fs-5">
                Voce nao possui permissao de perfil suficiente para visualizar ou executar acoes nesta area.
            </p>
            <p class="text-muted small mb-4">
                Se voce acredita que isso e um erro de configuracao, entre em contato com o administrador do sistema.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-gradient">
                    <i class="bi bi-house-door-fill me-2"></i>Ir para o Dashboard
                </a>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-glass">
                    <i class="bi bi-box-arrow-right me-2"></i>Entrar com Outra Conta
                </a>
            </div>
        </div>
    </div>
</div>
