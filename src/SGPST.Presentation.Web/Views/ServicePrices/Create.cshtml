@model SGPST.Application.DTOs.ServicePrice.CreateServicePriceDto
@{
    ViewData["Title"] = "Adicionar Servico";
    Layout = "_Layout";
}

<div class="row justify-content-center animate-fade-in">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-glass btn-sm me-3"><i class="bi bi-arrow-left"></i> Voltar</a>
            <div>
                <h2 class="text-light mb-0"><i class="bi bi-tag-fill me-2"></i>Adicionar Servico ao Catalogo</h2>
                <p class="text-secondary mb-0">Registre uma nova modalidade de suporte tecnico e seu valor base.</p>
            </div>
        </div>

        <div class="glass-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-4">
                    <label for="Name" class="form-label text-secondary">Nome do Servico</label>
                    <input type="text" id="Name" name="Name" class="form-control form-glass" placeholder="Ex: Manutencao de Servidor de Rede" required maxlength="100" />
                </div>

                <div class="mb-4">
                    <label for="Description" class="form-label text-secondary">Descricao Detalhada</label>
                    <textarea id="Description" name="Description" rows="4" class="form-control form-glass" placeholder="Descreva o escopo coberto por este servico..." required></textarea>
                </div>

                <div class="mb-4">
                    <label for="Price" class="form-label text-secondary">Preco / Valor Base (R$)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-secondary">R$</span>
                        <input type="number" step="0.01" id="Price" name="Price" class="form-control form-glass" placeholder="150.00" required min="0" />
                    </div>
                    <div class="form-text text-muted">Este valor sera o ponto de partida no faturamento das ordens de servico concluida.</div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5">
                    <a asp-action="Index" class="btn btn-glass py-3 px-4">Cancelar</a>
                    <button type="submit" class="btn btn-gradient py-3 px-4">
                        <i class="bi bi-check-lg me-2"></i>Adicionar Servico
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
