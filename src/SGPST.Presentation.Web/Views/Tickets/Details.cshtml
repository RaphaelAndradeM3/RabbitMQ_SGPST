@model SGPST.Application.DTOs.SupportTicket.SupportTicketDto
@{
    ViewData["Title"] = $"Chamado #{Model.Id.ToString().Substring(0, 8)}";
    Layout = "_Layout";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;
    
    var displacementLogs = ViewBag.DisplacementLogs as IEnumerable<SGPST.Domain.Entities.DisplacementLog>;
    var availableTechs = ViewBag.AvailableTechnicians as IEnumerable<SGPST.Application.DTOs.Technician.TechnicianDto>;
    var servicePrices = ViewBag.ServicePrices as IEnumerable<SGPST.Application.DTOs.ServicePrice.ServicePriceDto>;

    var statusCssClass = Model.Status switch
    {
        1 => "aberto",
        2 => "emtriagem",
        3 => "emdeslocamento",
        4 => "ematendimento",
        5 => "concluido",
        6 => "cancelado",
        _ => "aberto"
    };

    var priorityCssClass = Model.Priority switch
    {
        1 => "baixa",
        2 => "media",
        3 => "alta",
        4 => "urgente",
        _ => "baixa"
    };
}

<div class="animate-fade-in">
    <!-- Cabecalho Operacional -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <a asp-action="Index" class="btn btn-glass btn-sm me-3"><i class="bi bi-arrow-left"></i> Voltar</a>
            <div>
                <h2 class="text-light mb-0">Chamado #@Model.Id.ToString().Substring(0, 8)...</h2>
                <span class="badge-status @statusCssClass me-2">@Model.StatusDescription</span>
                <span class="badge-priority @priorityCssClass">Prioridade: @Model.PriorityDescription</span>
            </div>
        </div>
        <div>
            <span class="text-secondary small">Aberto em: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        </div>
    </div>

    <!-- Alertas de Sucesso / Erro -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-success bg-opacity-15 text-success border border-success border-opacity-25 rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show bg-danger bg-opacity-15 text-danger border border-danger border-opacity-25 rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Coluna da Esquerda: Detalhes do Chamado -->
        <div class="col-lg-8">
            <!-- Card de Descricao -->
            <div class="glass-card mb-4">
                <h4 class="text-light border-bottom border-secondary pb-2 mb-3">@Model.Title</h4>
                <p class="text-light fs-6" style="white-space: pre-line;">@Model.Description</p>
            </div>

            <!-- Historico de Deslocamentos (apenas para presencial) -->
            @if (Model.Type == 2)
            {
                <div class="glass-card mb-4">
                    <h4 class="text-light mb-4"><i class="bi bi-truck me-2"></i>Logs de Deslocamento do Tecnico</h4>
                    
                    @if (displacementLogs == null || !displacementLogs.Any())
                    {
                        <p class="text-secondary mb-0">Nenhum log de deslocamento registrado para este chamado.</p>
                    }
                    else
                    {
                        <div class="timeline ms-2 border-start border-secondary ps-3" style="position: relative;">
                            @foreach (var log in displacementLogs.OrderBy(l => l.DepartureTime))
                            {
                                <div class="mb-4" style="position: relative;">
                                    <div class="bg-primary rounded-circle border border-dark" style="position: absolute; left: -24px; top: 4px; width: 14px; height: 14px;"></div>
                                    <span class="text-accent small font-weight-bold d-block">Saida: @log.DepartureTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                    <span class="text-secondary small d-block">Origem: @log.StartLocation</span>
                                    
                                    @if (log.ArrivalTime.HasValue)
                                    {
                                        <span class="text-success small font-weight-bold d-block mt-2">Chegada: @log.ArrivalTime.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                        <span class="text-secondary small d-block">Destino: @log.EndLocation</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning small font-weight-bold d-block mt-2"><i class="bi bi-hourglass-split me-1"></i>A caminho...</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Informacoes de Triagem e Resumo de Faturamento -->
            <div class="glass-card mb-4">
                <h4 class="text-light mb-3"><i class="bi bi-info-circle me-2"></i>Informacoes Gerais</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <span class="text-secondary d-block">Cliente:</span>
                        <strong class="text-light">@Model.ClientName</strong>
                    </div>
                    <div class="col-md-6">
                        <span class="text-secondary d-block">Tipo de Atendimento:</span>
                        <strong class="text-light">
                            <i class="bi @(Model.Type == 1 ? "bi-laptop" : "bi-geo-alt-fill") me-1"></i>@Model.TypeDescription
                        </strong>
                    </div>
                    <div class="col-md-6">
                        <span class="text-secondary d-block">Atendente Designado:</span>
                        <strong class="text-light">@(Model.AttendantName ?? "Nenhum atendente vinculado")</strong>
                    </div>
                    <div class="col-md-6">
                        <span class="text-secondary d-block">Tecnico Designado:</span>
                        <strong class="text-light">@(Model.TechnicianName ?? "Nenhum tecnico designado")</strong>
                    </div>

                    @if (Model.Status == 5)
                    {
                        <div class="col-12 mt-4 pt-3 border-top border-secondary">
                            <div class="row">
                                <div class="col-md-4">
                                    <span class="text-secondary d-block">Servico Faturado:</span>
                                    <strong class="text-light">@Model.ServicePriceName</strong>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary d-block">Custo Total:</span>
                                    <strong class="text-success fs-5">@Model.TotalCost.ToString("C")</strong>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary d-block">Finalizado em:</span>
                                    <strong class="text-light">@Model.ClosedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Coluna da Direita: Painel de Controle Operacional (Botoes de Acao) -->
        <div class="col-lg-4">
            <div class="glass-card mb-4">
                <h4 class="text-light mb-4"><i class="bi bi-gear-wide-connected me-2"></i>Controle de Status</h4>

                @if (Model.Status == 5)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-check-circle text-success fs-1"></i>
                        <h5 class="text-success mt-3 font-weight-bold">Chamado Concluido</h5>
                        <p class="text-secondary small">Este chamado ja foi faturado e arquivado.</p>
                    </div>
                }
                else if (Model.Status == 6)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-x-circle text-danger fs-1"></i>
                        <h5 class="text-danger mt-3 font-weight-bold">Chamado Cancelado</h5>
                        <p class="text-secondary small">Este chamado foi cancelado e encerrado.</p>
                    </div>
                }
                else
                {
                    <!-- Painel de acoes para Admin e Atendente -->
                    @if (userRole == "Admin" || userRole == "Atendente")
                    {
                        @if (Model.Status == 1) // Aberto
                        {
                            <form asp-action="AssignAttendant" method="post" class="mb-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@Model.Id" />
                                <button type="submit" class="btn btn-gradient w-100 py-3">
                                    <i class="bi bi-play-fill me-2"></i>Iniciar Triagem
                                </button>
                            </form>
                        }
                        else if (Model.Status == 2) // Em Triagem
                        {
                            <div class="mb-4">
                                <h6 class="text-secondary mb-3">Designar Tecnico para Atendimento</h6>
                                <form asp-action="AssignTechnician" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ticketId" value="@Model.Id" />
                                    <div class="mb-3">
                                        <select name="technicianId" class="form-select form-glass" required>
                                            <option value="">Selecione o tecnico...</option>
                                            @if (availableTechs != null)
                                            {
                                                foreach (var tech in availableTechs)
                                                {
                                                    <option value="@tech.Id">@tech.Username (@tech.Specialty)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <button type="submit" class="btn btn-gradient w-100 py-2">
                                        <i class="bi bi-person-plus me-2"></i>Designar Tecnico
                                    </button>
                                </form>
                            </div>
                        }
                    }

                    <!-- Painel de Acoes para Tecnico (ou Admin para fins de teste) -->
                    @if (userRole == "Tecnico" || userRole == "Admin" || userRole == "Atendente")
                    {
                        @if (Model.Status == 3) // Em Deslocamento (apenas presencial)
                        {
                            var activeLog = displacementLogs?.FirstOrDefault(l => !l.ArrivalTime.HasValue);
                            if (activeLog == null)
                            {
                                <div class="mb-4">
                                    <h6 class="text-secondary mb-3">Iniciar Deslocamento Fisico</h6>
                                    <form asp-action="StartDisplacement" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ticketId" value="@Model.Id" />
                                        <div class="mb-3">
                                            <input type="text" name="startLocation" class="form-control form-glass" placeholder="Origem (Ex: Base Operacional)" />
                                        </div>
                                        <button type="submit" class="btn btn-gradient w-100 py-2">
                                            <i class="bi bi-truck me-2"></i>Iniciar Viagem
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <div class="mb-4">
                                    <h6 class="text-secondary mb-3">Registrar Chegada no Cliente</h6>
                                    <form asp-action="EndDisplacement" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ticketId" value="@Model.Id" />
                                        <div class="mb-3">
                                            <input type="text" name="endLocation" class="form-control form-glass" placeholder="Destino (Ex: Av. Paulista, 1000)" />
                                        </div>
                                        <button type="submit" class="btn btn-success w-100 py-2">
                                            <i class="bi bi-geo-alt me-2"></i>Cheguei ao Local
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        else if (Model.Status == 4) // Em Atendimento
                        {
                            <div class="mb-4">
                                <h6 class="text-secondary mb-3">Concluir Chamado (Faturamento)</h6>
                                <form asp-action="Complete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ticketId" value="@Model.Id" />
                                    
                                    <div class="mb-3">
                                        <label class="form-label text-secondary small">Servico Realizado</label>
                                        <select name="servicePriceId" class="form-select form-glass" required>
                                            <option value="">Selecione o servico prestado...</option>
                                            @if (servicePrices != null)
                                            {
                                                foreach (var service in servicePrices)
                                                {
                                                    <option value="@service.Id">@service.Name (@service.Price.ToString("C"))</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label text-secondary small">Custo Adicional (Deslocamento / Pecas)</label>
                                        <input type="number" step="0.01" name="extraCost" value="0.00" class="form-control form-glass" required min="0" />
                                    </div>

                                    <button type="submit" class="btn btn-success w-100 py-3">
                                        <i class="bi bi-patch-check-fill me-2"></i>Concluir & Faturar
                                    </button>
                                </form>
                            </div>
                        }
                    }

                    <!-- Cancelamento de Chamado (Disponivel para todos) -->
                    <div class="mt-4 pt-3 border-top border-secondary">
                        <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="collapse" data-bs-target="#cancelArea" aria-expanded="false" aria-controls="cancelArea">
                            <i class="bi bi-x-lg me-2"></i>Cancelar Chamado
                        </button>
                        
                        <div class="collapse mt-3" id="cancelArea">
                            <form asp-action="Cancel" method="post" class="bg-dark bg-opacity-25 p-3 rounded border border-danger border-opacity-25">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@Model.Id" />
                                <div class="mb-3">
                                    <label class="form-label text-secondary small">Motivo do Cancelamento</label>
                                    <textarea name="reason" rows="3" class="form-control form-glass" placeholder="Descreva brevemente o motivo do cancelamento..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-danger w-100 py-2">
                                    Confirmar Cancelamento
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
