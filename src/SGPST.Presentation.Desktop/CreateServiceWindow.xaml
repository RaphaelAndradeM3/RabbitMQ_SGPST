<Window x:Class="SGPST.Presentation.Desktop.CreateServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SGPST.Presentation.Desktop"
        mc:Ignorable="d"
        Title="Adicionar Servico ao Catalogo" Height="420" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0a0b10" BorderBrush="#262a40" BorderThickness="1">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titulo -->
        <TextBlock Grid.Row="0" Text="Novo Servico no Catalogo" FontSize="20" FontWeight="Bold" Margin="0,0,0,20">
            <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7c4dff" Offset="0.0"/>
                    <GradientStop Color="#00e5ff" Offset="1.0"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
        </TextBlock>

        <!-- Formulario -->
        <StackPanel Grid.Row="1">
            <!-- Nome do Servico -->
            <TextBlock Text="Nome do Servico" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtName" Margin="0,0,0,15" FontSize="14"/>

            <!-- Descricao -->
            <TextBlock Text="Descricao do Servico" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDescription" Height="80" Margin="0,0,0,15" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>

            <!-- Preco -->
            <TextBlock Text="Preco Base (R$)" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtPrice" Margin="0,0,0,15" FontSize="14"/>
        </StackPanel>

        <!-- Botoes -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" Content="Cancelar" Style="{StaticResource FlatButton}" Margin="0,0,10,0" Width="100" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Cadastrar" Style="{StaticResource GradientButton}" Width="150" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
