<Window x:Class="SGPST.Presentation.Desktop.CreateClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SGPST.Presentation.Desktop"
        mc:Ignorable="d"
        Title="Cadastrar Novo Cliente" Height="580" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0a0b10" BorderBrush="#262a40" BorderThickness="1">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titulo -->
        <TextBlock Grid.Row="0" Text="Cadastrar Novo Cliente" FontSize="20" FontWeight="Bold" Margin="0,0,0,20">
            <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7c4dff" Offset="0.0"/>
                    <GradientStop Color="#00e5ff" Offset="1.0"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
        </TextBlock>

        <!-- Formulario Grid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Linha 1: Nome e Documento -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                <TextBlock Text="Nome / Razao Social" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtName" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                <TextBlock Text="Documento (CNPJ/CPF)" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtDocument" FontSize="14"/>
            </StackPanel>

            <!-- Linha 2: E-mail e Telefone -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                <TextBlock Text="E-mail" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtEmail" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                <TextBlock Text="Telefone" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtPhone" FontSize="14"/>
            </StackPanel>

            <!-- Linha Divisoria Endereço -->
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Endereço de Atendimento" FontWeight="Bold" Foreground="#7c4dff" Margin="0,10,0,10"/>

            <!-- Linha 3: Logradouro e CEP -->
            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,12">
                <TextBlock Text="Logradouro, Numero e Compl." FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtAddress" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,12">
                <TextBlock Text="CEP" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtZipCode" FontSize="14"/>
            </StackPanel>

            <!-- Linha 4: Bairro e Cidade -->
            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,12">
                <TextBlock Text="Bairro" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtNeighborhood" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="1" Margin="10,0,0,12">
                <TextBlock Text="Cidade" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtCity" FontSize="14"/>
            </StackPanel>

            <!-- Linha 5: Estado -->
            <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,10,12">
                <TextBlock Text="Estado (UF)" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtState" FontSize="14" MaxLength="2"/>
            </StackPanel>
        </Grid>

        <!-- Botoes de Acao -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" Content="Cancelar" Style="{StaticResource FlatButton}" Margin="0,0,10,0" Width="100" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Cadastrar" Style="{StaticResource GradientButton}" Width="150" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
