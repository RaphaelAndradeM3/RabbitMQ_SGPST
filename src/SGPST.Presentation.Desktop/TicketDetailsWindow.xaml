<Window x:Class="SGPST.Presentation.Desktop.TicketDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SGPST.Presentation.Desktop"
        mc:Ignorable="d"
        Title="Detalhes do Chamado" Height="680" Width="950"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#0a0b10" BorderBrush="#262a40" BorderThickness="1">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Coluna Esquerda: Detalhes e Historico de Deslocamentos -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecalho do Chamado -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="TxtTicketId" Text="ID: #00000000" FontSize="11" Foreground="#9ca3af" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtTitle" Text="Carregando..." FontSize="22" FontWeight="Bold" Margin="0,2,0,5" TextWrapping="Wrap">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7c4dff" Offset="0.0"/>
                            <GradientStop Color="#00e5ff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" x:Name="BdrStatus" Background="#1e2030">
                    <TextBlock x:Name="TxtStatus" Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Painel de Informacoes Detalhadas -->
            <Border Grid.Row="1" Background="#161a2b" BorderBrush="#262a40" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Linha 1: Cliente e Prioridade -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="CLIENTE SOLICITANTE" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtClient" Text="-" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="PRIORIDADE" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtPriority" Text="-" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Linha 2: Tipo de Atendimento e Data de Criacao -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="TIPO" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtType" Text="-" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="DATA DE ABERTURA" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtCreatedAt" Text="-" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Linha 3: Atendente e Tecnico -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="ATENDENTE RESPONSAVEL" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtAttendant" Text="Nao atribuido" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="TECNICO DESIGNADO" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtTechnician" Text="Nao designado" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Linha 4: Servico Prestado e Faturamento -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="SERVICO PRESTADO" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtServicePrice" Text="Nao faturado" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="VALOR TOTAL COBRADO" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtTotalCost" Text="R$ 0,00" FontSize="13" Foreground="#00e5ff" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Linha 5: Descricao do Chamado (Span Columns) -->
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,5,0,0">
                        <TextBlock Text="DESCRICAO DO PROBLEMA" FontSize="10" Foreground="#9ca3af" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtDescription" FontSize="13" Text="-" Background="#121420" IsReadOnly="True" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" Height="70" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Grid de Deslocamentos (Somente para chamados presenciais) -->
            <Grid Grid.Row="2" x:Name="PnlDisplacements" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Historico de Deslocamentos do Tecnico" FontSize="14" FontWeight="Bold" Foreground="#7c4dff" Margin="0,0,0,8"/>
                
                <DataGrid Grid.Row="1" x:Name="GridDisplacements" HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="1" BorderBrush="#262a40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Saida" Binding="{Binding DepartureTime, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="1.2*"/>
                        <DataGridTextColumn Header="Origem" Binding="{Binding StartLocation}" Width="1.5*"/>
                        <DataGridTextColumn Header="Chegada" Binding="{Binding ArrivalTime, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="1.2*"/>
                        <DataGridTextColumn Header="Destino" Binding="{Binding EndLocation}" Width="1.5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Coluna Direita: Painel de Acoes Dinamicas -->
        <Border Grid.Column="1" Background="#121420" BorderBrush="#262a40" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Titulo do Painel -->
                <TextBlock Grid.Row="0" Text="Acoes do Chamado" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                <!-- Area de Formularios de Acao -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        
                        <!-- Acao 1: Iniciar Triagem (Status 1 -> Aberto) -->
                        <StackPanel x:Name="PnlAssignAttendant" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Este chamado esta aberto. Inicie a triagem para assumir o chamado." TextWrapping="Wrap" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,10"/>
                            <Button x:Name="BtnAssignAttendant" Content="⚡ Iniciar Triagem" Style="{StaticResource GradientButton}" Click="BtnAssignAttendant_Click"/>
                        </StackPanel>

                        <!-- Acao 2: Designar Tecnico (Status 2 -> EmTriagem) -->
                        <StackPanel x:Name="PnlAssignTechnician" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Designar Tecnico para Atendimento" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="CboTechnicians" DisplayMemberPath="Username" SelectedValuePath="Id" Height="36" Margin="0,0,0,10"/>
                            <Button x:Name="BtnAssignTechnician" Content="Designar Tecnico" Style="{StaticResource GradientButton}" Click="BtnAssignTechnician_Click"/>
                        </StackPanel>

                        <!-- Acao 2.5: Assumir Chamado como Tecnico (Status 1 ou 2, para Tecnico) -->
                        <StackPanel x:Name="PnlSelfAssignTechnician" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Este chamado esta pendente de tecnico. Voce pode assumir a responsabilidade por ele." TextWrapping="Wrap" FontSize="12" Foreground="#9ca3af" Margin="0,0,0,10"/>
                            <Button x:Name="BtnSelfAssignTechnician" Content="👷 Assumir Chamado" Style="{StaticResource GradientButton}" Click="BtnSelfAssignTechnician_Click"/>
                        </StackPanel>

                        <!-- Acao 3: Iniciar Deslocamento (Status 3 -> EmDeslocamento e sem viagem ativa) -->
                        <StackPanel x:Name="PnlStartDisplacement" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Iniciar Deslocamento Fisico" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtStartLocation" Text="Base Operacional" Margin="0,0,0,10" Height="36"/>
                            <Button x:Name="BtnStartDisplacement" Content="🚗 Iniciar Viagem" Style="{StaticResource GradientButton}" Click="BtnStartDisplacement_Click"/>
                        </StackPanel>

                        <!-- Acao 4: Registrar Chegada (Status 3 -> EmDeslocamento e com viagem ativa) -->
                        <StackPanel x:Name="PnlEndDisplacement" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Registrar Chegada no Local do Cliente" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtEndLocation" Text="Local do Cliente" Margin="0,0,0,10" Height="36"/>
                            <Button x:Name="BtnEndDisplacement" Content="📍 Registrar Chegada" Style="{StaticResource GradientButton}" Click="BtnEndDisplacement_Click"/>
                        </StackPanel>

                        <!-- Acao 5: Concluir Chamado (Status 4 -> EmAtendimento) -->
                        <StackPanel x:Name="PnlCompleteTicket" Visibility="Collapsed" Margin="0,0,0,15">
                            <TextBlock Text="Servico Realizado do Catalogo" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="CboServicePrices" DisplayMemberPath="Name" SelectedValuePath="Id" Height="36" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Custo Extra / Deslocamento (R$)" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtExtraCost" Text="0.00" Margin="0,0,0,15" Height="36"/>
                            
                            <Button x:Name="BtnCompleteTicket" Content="✔️ Concluir e Faturar" Style="{StaticResource GradientButton}" Click="BtnCompleteTicket_Click"/>
                        </StackPanel>

                        <!-- Mensagem informativa se Concluido ou Cancelado -->
                        <StackPanel x:Name="PnlClosedInfo" Visibility="Collapsed" Margin="0,0,0,15">
                            <Border BorderBrush="#262a40" BorderThickness="1" Background="#161a2b" CornerRadius="6" Padding="12">
                                <TextBlock x:Name="TxtClosedMsg" Text="Este chamado ja foi encerrado." TextWrapping="Wrap" FontSize="12" Foreground="#9ca3af"/>
                            </Border>
                        </StackPanel>

                        <!-- Secao de Cancelamento (Disponivel enquanto nao estiver concluido/cancelado) -->
                        <StackPanel x:Name="PnlCancelTicket" Visibility="Collapsed" Margin="0,20,0,0">
                            <Separator Background="#262a40" Margin="0,0,0,15"/>
                            <TextBlock Text="Cancelar Chamado" FontSize="12" FontWeight="Bold" Foreground="#ef4444" Margin="0,0,0,5"/>
                            <TextBlock Text="Justificativa do Cancelamento" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtCancelReason" Margin="0,0,0,10" Height="50" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>
                            <Button x:Name="BtnCancelTicket" Content="❌ Cancelar Chamado" Style="{StaticResource FlatButton}" BorderBrush="#ef4444" Foreground="#ef4444" Click="BtnCancelTicket_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Botao de Fechar Janela -->
                <Button Grid.Row="2" Content="Voltar" Style="{StaticResource FlatButton}" HorizontalAlignment="Stretch" Margin="0,15,0,0" Click="BtnBack_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
