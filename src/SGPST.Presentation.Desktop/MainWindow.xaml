<Window x:Class="SGPST.Presentation.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SGPST.Presentation.Desktop"
        mc:Ignorable="d"
        Title="SGPST Enterprise - Dashboard" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#0a0b10">
    
    <Window.Resources>
        <!-- Estilo customizado para os botoes do Menu Lateral -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="#1a1c2c"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="Background" Value="#171926"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#7c4dff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL (Sidebar) -->
        <Grid Grid.Column="0" Background="#121420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / Nome do App -->
            <StackPanel Grid.Row="0" Margin="20,25,20,25">
                <TextBlock Text="SGPST Enterprise" FontSize="20" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7c4dff" Offset="0.0"/>
                            <GradientStop Color="#00e5ff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <Border Height="1" Background="#262a40" Margin="0,15,0,0"/>
            </StackPanel>

            <!-- Botoes de Navegacao -->
            <StackPanel Grid.Row="1">
                <Button x:Name="BtnNavTickets" Content="🎫 Chamados" Style="{StaticResource SidebarButton}" Click="BtnNavTickets_Click"/>
                <Button x:Name="BtnNavClients" Content="👥 Clientes" Style="{StaticResource SidebarButton}" Click="BtnNavClients_Click"/>
                <Button x:Name="BtnNavTechs" Content="🛠️ Tecnicos" Style="{StaticResource SidebarButton}" Click="BtnNavTechs_Click"/>
                <Button x:Name="BtnNavCatalog" Content="🏷️ Catalogo de Servicos" Style="{StaticResource SidebarButton}" Click="BtnNavCatalog_Click"/>
            </StackPanel>

            <!-- Informacoes do Usuario Logado -->
            <Border Grid.Row="3" Background="#0a0b10" BorderBrush="#262a40" BorderThickness="0,1,0,0" Padding="15">
                <StackPanel>
                    <TextBlock x:Name="TxtUserLogged" Text="Usuario: admin" FontWeight="Bold" Foreground="White" FontSize="13"/>
                    <TextBlock x:Name="TxtRoleLogged" Text="Perfil: Admin" Foreground="#9ca3af" FontSize="11" Margin="0,3,0,10"/>
                    <Button x:Name="BtnLogout" Content="Sair do Sistema" Style="{StaticResource FlatButton}" BorderBrush="#ef4444" Foreground="#ef4444" Padding="10,6" Click="BtnLogout_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- AREA DE CONTEUDO PRINCIPAL -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra Superior de Controle -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtActivePageTitle" Text="Chamados de Suporte" FontSize="24" FontWeight="Bold" Grid.Column="0" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnRefresh" Content="🔄 Atualizar" Style="{StaticResource FlatButton}" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnActionPage" Content="➕ Novo Chamado" Style="{StaticResource GradientButton}" Click="BtnActionPage_Click"/>
                </StackPanel>
            </Grid>

            <!-- Container de Abas (TabControl com Headers ocultos) -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" BorderThickness="0" Background="Transparent">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- ABA 1: CHAMADOS (Tickets) -->
                <TabItem Header="Chamados">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filtro de Status -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Filtrar por Status:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#9ca3af"/>
                            <ComboBox x:Name="CboStatusFilter" Width="200" VerticalAlignment="Center" SelectionChanged="CboStatusFilter_SelectionChanged">
                                <ComboBoxItem Content="Todos os Status" IsSelected="True"/>
                                <ComboBoxItem Content="Aberto"/>
                                <ComboBoxItem Content="Em Triagem"/>
                                <ComboBoxItem Content="Em Deslocamento"/>
                                <ComboBoxItem Content="Em Atendimento"/>
                                <ComboBoxItem Content="Concluido"/>
                                <ComboBoxItem Content="Cancelado"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Tabela de Chamados -->
                        <DataGrid x:Name="GridTickets" Grid.Row="1" MouseDoubleClick="GridTickets_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="*"/>
                                <DataGridTextColumn Header="Titulo" Binding="{Binding Title}" Width="2*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusDescription}" Width="110"/>
                                <DataGridTextColumn Header="Prioridade" Binding="{Binding PriorityDescription}" Width="100"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding TypeDescription}" Width="100"/>
                                <DataGridTextColumn Header="Preco Total" Binding="{Binding TotalCost, StringFormat=C}" Width="100"/>
                                <DataGridTextColumn Header="Abertura" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ABA 2: CLIENTES -->
                <TabItem Header="Clientes">
                    <DataGrid x:Name="GridClients">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome / Razao Social" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Documento" Binding="{Binding Document}" Width="*"/>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="1.5*"/>
                            <DataGridTextColumn Header="Telefone" Binding="{Binding Phone}" Width="*"/>
                            <DataGridTextColumn Header="Endereço" Binding="{Binding AddressLine}" Width="2*"/>
                            <DataGridTextColumn Header="Cidade/UF" Binding="{Binding City}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ABA 3: TECNICOS -->
                <TabItem Header="Tecnicos">
                    <DataGrid x:Name="GridTechnicians">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="1.5*"/>
                            <DataGridTextColumn Header="Especialidade" Binding="{Binding Specialty}" Width="2*"/>
                            <DataGridTextColumn Header="Localizacao" Binding="{Binding CurrentLocation}" Width="1.5*"/>
                            <DataGridCheckBoxColumn Header="Disponivel" Binding="{Binding IsAvailable}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ABA 4: CATALOGO -->
                <TabItem Header="Catalogo">
                    <DataGrid x:Name="GridCatalog">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome do Servico" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Descricao" Binding="{Binding Description}" Width="3*"/>
                            <DataGridTextColumn Header="Valor Base" Binding="{Binding Price, StringFormat=C}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
